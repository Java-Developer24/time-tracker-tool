# Copy this file to .env and fill in your values
API_KEY=testkey123
PORT=3000
VERBOSE_LOGS=true

# BigQuery configuration
# Set BQ_PROJECT_ID explicitly if GOOGLE_CLOUD_PROJECT is not set in the runtime.
BQ_PROJECT_ID=project-46367cfc-2a49-49cc-8be
BQ_LOCATION=US
BQ_DATASET=timetracker
BQ_ACTIVITY_TABLE=activity_logs
BQ_STATUS_TABLE=agent_status
BQ_DAILY_SUMMARY_VIEW=daily_summary
GOOGLE_APPLICATION_CREDENTIALS=./project-46367cfc-2a49-49cc-8be-37d853999b24.json
# Optional OHR lookup configuration (defaults are already set in server.js)
OHR_SHEET_ID=1KlfU6Juc2vlErxgRoDEGLq6trNIyjqUNMjmr3q7K6vM
OHR_SHEET_GID=0
# OHR_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/<SHEET_ID>/export?format=csv&gid=0

# Optional webhook to write registration timestamp externally (e.g. Apps Script)
# OHR_TIMESTAMP_WEBHOOK_URL=https://script.google.com/macros/s/xxxx/exec

# Optional: only if your server cannot validate Google TLS certificates
# ALLOW_INSECURE_TLS=true
